<Window x:Class="ClaudeAlert.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">

    <Grid x:Name="PetContainer" Background="Transparent" ClipToBounds="False">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Speech bubble (Row 0) — uses full width, won't clip -->
        <StackPanel x:Name="BubblePanel" Grid.Row="0"
                    HorizontalAlignment="Center"
                    Visibility="Collapsed"
                    Margin="0,0,0,2"
                    MinWidth="200">
            <Border x:Name="SpeechBubble"
                    Background="White"
                    CornerRadius="8"
                    Padding="8,4">
                <TextBlock x:Name="BubbleText"
                           FontSize="11"
                           Foreground="#333"
                           FontFamily="Segoe UI"
                           TextAlignment="Center"
                           TextWrapping="NoWrap"/>
            </Border>
            <Polygon Points="0,0 10,0 5,6"
                     Fill="White"
                     HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Pet image (Row 1) — transforms applied here only -->
        <Image x:Name="PetImage" Grid.Row="1"
               Width="64" Height="64"
               HorizontalAlignment="Center"
               Stretch="Uniform"
               RenderOptions.BitmapScalingMode="NearestNeighbor"
               RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="SquashTransform" ScaleX="1" ScaleY="1"/>
                    <RotateTransform x:Name="RotateTransform" Angle="0"/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
    </Grid>
</Window>
