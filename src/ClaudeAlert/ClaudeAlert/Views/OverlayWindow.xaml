<Window x:Class="ClaudeAlert.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">

    <Grid x:Name="PetContainer" Background="Transparent">
        <Grid.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="SquashTransform" ScaleX="1" ScaleY="1"/>
                <RotateTransform x:Name="RotateTransform" Angle="0"/>
            </TransformGroup>
        </Grid.RenderTransform>

        <!-- Speech bubble (above image) -->
        <Border x:Name="SpeechBubble"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Margin="0,-36,0,0"
                Background="White"
                CornerRadius="8"
                Padding="8,4"
                Visibility="Collapsed"
                RenderTransformOrigin="0.5,1">
            <Border.RenderTransform>
                <RotateTransform x:Name="BubbleCounterRotate" Angle="0"/>
            </Border.RenderTransform>
            <TextBlock x:Name="BubbleText"
                       FontSize="11"
                       Foreground="#333"
                       FontFamily="Segoe UI"
                       TextAlignment="Center"/>
        </Border>

        <!-- Bubble tail (triangle pointing down) -->
        <Polygon x:Name="BubbleTail"
                 Points="0,0 10,0 5,6"
                 Fill="White"
                 VerticalAlignment="Top"
                 HorizontalAlignment="Center"
                 Margin="0,-6,0,0"
                 Visibility="Collapsed"/>

        <!-- Pet image -->
        <Image x:Name="PetImage"
               Width="64" Height="64"
               VerticalAlignment="Bottom"
               Stretch="Uniform"
               RenderOptions.BitmapScalingMode="HighQuality"/>
    </Grid>
</Window>
