<Window x:Class="ClaudeAlert.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">

    <Grid x:Name="PetContainer" Width="80" Height="100" Background="Transparent">
        <Grid.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="SquashTransform" ScaleX="1" ScaleY="1" CenterX="40" CenterY="80"/>
                <RotateTransform x:Name="RotateTransform" Angle="0" CenterX="40" CenterY="50"/>
            </TransformGroup>
        </Grid.RenderTransform>

        <!-- Pet image -->
        <Image x:Name="PetImage"
               Width="64" Height="64"
               Margin="8,0,8,0"
               VerticalAlignment="Top"
               Stretch="Uniform"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <!-- Status label below image -->
        <Border VerticalAlignment="Bottom"
                Height="28"
                Background="#CC1E1E1E"
                CornerRadius="4"
                Padding="4,2">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <TextBlock x:Name="StatusLabel"
                           Text="대기"
                           Foreground="#CCCCCC"
                           FontSize="10"
                           TextAlignment="Center"
                           FontFamily="Segoe UI"/>
                <TextBlock x:Name="ElapsedLabel"
                           Text=""
                           Foreground="#888888"
                           FontSize="9"
                           TextAlignment="Center"
                           FontFamily="Segoe UI"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
