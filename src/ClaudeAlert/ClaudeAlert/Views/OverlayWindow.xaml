<Window x:Class="ClaudeAlert.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">

    <Canvas x:Name="PetContainer" Background="Transparent">
        <!-- Pet image — transforms applied here only -->
        <Image x:Name="PetImage"
               Canvas.Left="0" Canvas.Top="40"
               Width="64" Height="64"
               Stretch="Uniform"
               RenderOptions.BitmapScalingMode="NearestNeighbor"
               RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="SquashTransform" ScaleX="1" ScaleY="1"/>
                    <RotateTransform x:Name="RotateTransform" Angle="0"/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>

        <!-- Speech bubble (positioned above image via Canvas) -->
        <StackPanel x:Name="BubblePanel"
                    Canvas.Left="0" Canvas.Top="0"
                    Visibility="Collapsed">
            <Border x:Name="SpeechBubble"
                    Background="White"
                    CornerRadius="8"
                    Padding="8,4">
                <TextBlock x:Name="BubbleText"
                           FontSize="11"
                           Foreground="#333"
                           FontFamily="Segoe UI"
                           TextAlignment="Center"/>
            </Border>
            <Polygon Points="0,0 10,0 5,6"
                     Fill="White"
                     HorizontalAlignment="Center"/>
        </StackPanel>
    </Canvas>
</Window>
