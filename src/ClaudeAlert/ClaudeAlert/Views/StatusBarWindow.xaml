<Window x:Class="ClaudeAlert.Views.StatusBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">

    <Border Background="#CC1E1E1E" CornerRadius="6" Padding="12,6" MinWidth="80">
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
            <TextBlock x:Name="StatusLabel"
                       Text="대기"
                       Foreground="#CCCCCC"
                       FontSize="11"
                       TextAlignment="Center"
                       FontFamily="Segoe UI"
                       FontWeight="SemiBold"/>
            <TextBlock x:Name="ElapsedLabel"
                       Text=""
                       Foreground="#888888"
                       FontSize="9"
                       TextAlignment="Center"
                       FontFamily="Segoe UI"/>
        </StackPanel>
    </Border>
</Window>
