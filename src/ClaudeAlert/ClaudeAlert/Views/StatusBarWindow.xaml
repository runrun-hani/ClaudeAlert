<Window x:Class="ClaudeAlert.Views.StatusBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">

    <StackPanel Orientation="Horizontal" MinHeight="30">
        <Border Background="#CC1E1E1E" CornerRadius="6" Padding="12,6" MinWidth="80">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <TextBlock x:Name="StatusLabel"
                           Text="대기"
                           Foreground="#CCCCCC"
                           FontSize="11"
                           TextAlignment="Center"
                           FontFamily="Segoe UI"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="ElapsedLabel"
                           Text=""
                           Foreground="#888888"
                           FontSize="9"
                           TextAlignment="Center"
                           FontFamily="Segoe UI"/>
            </StackPanel>
        </Border>
        <Border x:Name="DebugPanel" Background="#CC000000" CornerRadius="6" Padding="8,4" Margin="4,0,0,0"
                MaxWidth="350" MaxHeight="200" Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="DebugLog"
                           Text=""
                           Foreground="#88FF88"
                           FontSize="9"
                           FontFamily="Consolas"
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
        <Border x:Name="FocusPanel" Background="#CC000000" CornerRadius="6" Padding="8,4" Margin="4,0,0,0"
                Visibility="Collapsed">
            <TextBlock x:Name="FocusStatus"
                       Text="Focus: ?"
                       Foreground="#88AAFF"
                       FontSize="9"
                       FontFamily="Consolas"/>
        </Border>
    </StackPanel>
</Window>
