<Window x:Class="ClaudeAlert.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClaudeAlert 설정"
        Width="400" Height="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E1E">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="ClaudeAlert 설정" FontSize="18" FontWeight="Bold"
                   Foreground="White" Margin="0,0,0,20"/>

        <!-- Port -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="HTTP 포트" Foreground="#CCCCCC" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="PortBox" Background="#2D2D2D" Foreground="White"
                     BorderBrush="#444" Padding="6,4" FontSize="13"/>
        </StackPanel>

        <!-- Stuck threshold -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="멈춤 감지 (초)" Foreground="#CCCCCC" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="StuckThresholdBox" Background="#2D2D2D" Foreground="White"
                     BorderBrush="#444" Padding="6,4" FontSize="13"/>
        </StackPanel>

        <!-- Escalation timings -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="에스컬레이션 타이밍 (초)" Foreground="#CCCCCC" FontSize="12" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="점프" Foreground="#888" FontSize="10" Margin="0,0,0,2"/>
                    <TextBox x:Name="JumpBox" Background="#2D2D2D" Foreground="White"
                             BorderBrush="#444" Padding="6,4" FontSize="13"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="굴러다니기" Foreground="#888" FontSize="10" Margin="0,0,0,2"/>
                    <TextBox x:Name="RollBox" Background="#2D2D2D" Foreground="White"
                             BorderBrush="#444" Padding="6,4" FontSize="13"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="튀어다니기" Foreground="#888" FontSize="10" Margin="0,0,0,2"/>
                    <TextBox x:Name="BounceBox" Background="#2D2D2D" Foreground="White"
                             BorderBrush="#444" Padding="6,4" FontSize="13"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Sound -->
        <CheckBox x:Name="SoundCheck" Grid.Row="4" Content="사운드 알림"
                  Foreground="#CCCCCC" FontSize="13" Margin="0,0,0,12"/>

        <!-- Auto start -->
        <CheckBox x:Name="AutoStartCheck" Grid.Row="5" Content="Windows 시작 시 자동 실행"
                  Foreground="#CCCCCC" FontSize="13" Margin="0,0,0,12"/>

        <!-- Image -->
        <StackPanel Grid.Row="6" Margin="0,0,0,12">
            <TextBlock Text="커스텀 이미지" Foreground="#CCCCCC" FontSize="12" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ImagePathBox" Grid.Column="0" Background="#2D2D2D" Foreground="White"
                         BorderBrush="#444" Padding="6,4" FontSize="12" IsReadOnly="True"/>
                <Button x:Name="BrowseButton" Grid.Column="1" Content="찾아보기" Margin="8,0,0,0"
                        Padding="12,4" Background="#3D3D3D" Foreground="White" BorderBrush="#555"
                        Click="OnBrowseClick"/>
            </Grid>
        </StackPanel>

        <!-- Hook status -->
        <StackPanel Grid.Row="7" Margin="0,0,0,12">
            <TextBlock Text="Claude Code 훅 상태" Foreground="#CCCCCC" FontSize="12" Margin="0,0,0,4"/>
            <TextBlock x:Name="HookStatusLabel" Foreground="#888" FontSize="11"/>
            <Button x:Name="ReconfigureButton" Content="훅 재설정" Margin="0,6,0,0"
                    Padding="12,4" Background="#3D3D3D" Foreground="White" BorderBrush="#555"
                    HorizontalAlignment="Left" Click="OnReconfigureClick"/>
        </StackPanel>

        <!-- Save/Cancel -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="취소" Padding="16,6" Margin="0,0,8,0"
                    Background="#3D3D3D" Foreground="White" BorderBrush="#555"
                    Click="OnCancelClick"/>
            <Button Content="저장" Padding="16,6"
                    Background="#0078D4" Foreground="White" BorderBrush="#0078D4"
                    Click="OnSaveClick"/>
        </StackPanel>
    </Grid>
</Window>
